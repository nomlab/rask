<div class="card h-100">
  <div class="card-body d-flex flex-column">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <small class="text-muted creator-badge">
        <i class="bi bi-person-fill"></i>
        <%= link_to_if document.creator&.screen_name, document.creator&.name, document.creator, class: "text-muted text-decoration-none" %>
      </small>
      
      <% if logged_in? %>
        <%= link_to edit_document_path(document), class: "text-muted text-decoration-none", title: "編集" do %>
          <i class="far fa-edit"></i>
        <% end %>
      <% end %>
    </div>
    
    <div class="mt-auto">
      <h5 class="card-title mb-2">
        <%= link_to document.content.truncate(30), document, class: "text-black text-decoration-none card-link" %>
      </h5>
      
      <div class="mb-2">
        <small class="text-muted"><%= document.start_at&.strftime('%Y/%m/%d') %></small>
      </div>
      
      <div style="min-height: 24px;">
        <% document.tags.each do |tag| %>
          <%= link_to tag, class: "tag-badge" do %>
            <i class="bi bi-hash"></i><%= tag.name %>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>